# GitRepoMind Configuration

# ── App Config ──────────────────────────────────────────────────
APP_NAME=GitRepoMind
APP_VERSION=0.1.0
DEBUG=False
LOG_LEVEL=INFO

# ── Server Config ──────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000

# ── Database Config ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/gitrepomind

# ── Redis/Celery Config ────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# ── OpenAI Config (optional for future use) ────────────────────
OPENAI_API_KEY=

# ── Embedding Config ───────────────────────────────────────────
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_BATCH_SIZE=16
EMBEDDING_DEVICE=cpu
EMBEDDING_DIMENSION=384

# ── Qdrant Vector Database Config ──────────────────────────────
QUADRANT_URL=http://localhost:6333
QUADRANT_API_KEY=
QDRANT_COLLECTION_NAME=gitrepomind_chunks
QDRANT_VECTOR_DIM=384

# ── GitHub Config ──────────────────────────────────────────────
GITHUB_TOKEN=

# ── Processing Config ────────────────────────────────────────
MAX_REPO_SIZE_GB=1.0
MAX_FILE_SIZE_MB=10.0
CHUNK_SIZE=1024
CHUNK_OVERLAP=128
SEARCH_TOP_K=5

# ── Ollama LLM Config ──────────────────────────────────────────
# Make sure Ollama is running before using the chat endpoint
# Download model: ollama pull qwen2.5-coder:7b
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_TEMPERATURE=0.2
OLLAMA_TOP_P=0.9
OLLAMA_TIMEOUT=60

# ── RAG Config ────────────────────────────────────────────────
RAG_TOP_K=5
RAG_MAX_CONTEXT_CHARS=12000
